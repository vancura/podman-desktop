{
  "feedback.dialog": true,
  "preferences.zoomLevel": 0.5,
  "preferences.ExitOnClose": false,
  "registries.preferred": "docker.io, quay.io",
  "registries.defaults": [
    {
      "registry": {
        "prefix": "docker.io",
        "location": "docker.io"
      }
    },
    {
      "registry": {
        "prefix": "quay.io",
        "location": "quay.io"
      }
    }
  ],
  "proxy.http": "http://managed-proxy.example.com:8080",
  "proxy.https": "https://managed-proxy.example.com:8443",
  "proxy.no": "localhost,127.0.0.1,.example.com"
}
